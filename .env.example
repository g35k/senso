# Supabase (project Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: where users land after email confirmation (defaults to /login on this origin)
# VITE_SUPABASE_EMAIL_REDIRECT_TO=http://localhost:5173/login

# Optional: where password reset email links send users (defaults to /reset-password on this origin)
# VITE_SUPABASE_PASSWORD_RESET_REDIRECT_TO=http://localhost:5173/reset-password

# In Supabase Dashboard → Authentication → URL Configuration, add Redirect URLs for
# /login (email confirmation) and /reset-password (password recovery), e.g.
# http://localhost:5173/login and http://localhost:5173/reset-password
# Root (/) forwards hash links: type=recovery → /reset-password, others → /login.
